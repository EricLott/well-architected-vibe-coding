{
  "name": "well-architected-vibe-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 1 deterministic ingestion and retrieval MVP",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest": "node --no-warnings --loader ts-node/esm scripts/ingest.ts",
    "dev": "node --no-warnings --loader ts-node/esm src/api/server.ts",
    "api": "npm run dev",
    "build:index": "node --no-warnings --loader ts-node/esm scripts/build-index.ts",
    "test:retrieve": "node --no-warnings --loader ts-node/esm scripts/test-retrieve.ts",
    "reset": "rimraf artifacts && npm run ingest"
  },
  "dependencies": {
    "express": "^4.21.2",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
